DISCORD_TOKEN=your_bot_token_here
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://timely:your_secure_password_here@db/timely

# Slash command group name — change to distinguish multiple instances
# Production: COMMAND_GROUP=timely  → /timely ...
# Dev:        COMMAND_GROUP=dev     → /dev ...
COMMAND_GROUP=timely
